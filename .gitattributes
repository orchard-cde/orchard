# Default: normalize line endings to LF on commit
* text=auto eol=lf

# Shell scripts must always be LF
*.sh text eol=lf
gradlew text eol=lf

# Windows batch files use CRLF
*.bat text eol=crlf
gradlew.bat text eol=crlf

# Java/Kotlin source
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf

# Config/data files
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.sql text eol=lf
*.md text eol=lf

# Binaries
*.png binary
*.jpg binary
*.jar binary
*.class binary
